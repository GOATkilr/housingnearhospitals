# Database (Neon serverless Postgres)
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/housing_near_hospitals?sslmode=require

# Site URL (used for canonical URLs, sitemap, OG tags)
NEXT_PUBLIC_SITE_URL=https://housingnearchospitals.com

# Mapbox (free tier: 50K map loads/month)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Google Maps (geocoding only)
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Auth (NextAuth.js)
NEXTAUTH_SECRET=your_secret_here
NEXTAUTH_URL=http://localhost:3000

# Analytics — Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Analytics — Plausible (self-hosted or cloud)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=housingnearchospitals.com
