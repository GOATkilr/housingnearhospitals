# Neon Postgres connection string (required for database)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Admin dashboard password (required for /admin)
ADMIN_PASSWORD=YourSecurePassword

# Mapbox (free tier: 50K map loads/month)
# IMPORTANT: NEXT_PUBLIC_* vars are inlined at build time — redeploy after changing
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Google Analytics (GA4 measurement ID)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# RentCast API (free tier: 50 calls/month)
RENTCAST_API_KEY=your_rentcast_api_key_here
